#!/usr/bin/env bash
#
# vigiaos-sync-user-config
#
# Sincroniza arquivos de configuracao default do VigiaOS (que ficam em /etc/skel/)
# para o diretorio home do usuario atual. Necessario porque:
#
#   1. /etc/skel/ so e copiado automaticamente para NOVOS usuarios criados via useradd
#   2. libadwaita le gtk.css apenas de ~/.config/gtk-4.0/ (nao de /etc/xdg)
#
# Idempotente: roda quantas vezes quiser, so cria links se nao existirem.
# Acionado por: /etc/profile.d/vigiaos-init.sh (em todo login shell)

set -euo pipefail

# Pares "destino:origem" para criar symlinks
LINKS=(
    "$HOME/.config/gtk-4.0/gtk.css:/etc/skel/.config/gtk-4.0/gtk.css"
    "$HOME/.config/gtk-3.0/gtk.css:/etc/skel/.config/gtk-3.0/gtk.css"
)

for entry in "${LINKS[@]}"; do
    dest="${entry%%:*}"
    src="${entry#*:}"

    # Pula se origem nao existe (recipe pode nao ter incluido esse arquivo)
    [ -e "$src" ] || continue
    # Pula se destino ja existe (arquivo, symlink ou diretorio)
    [ -e "$dest" ] && continue

    mkdir -p "$(dirname "$dest")"
    ln -sf "$src" "$dest"
done

# Marca como inicializado para evitar reprocessamento desnecessario
mkdir -p "$HOME/.config/vigiaos"
touch "$HOME/.config/vigiaos/initialized"
